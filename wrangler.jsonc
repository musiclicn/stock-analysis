{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stock-analysis",
  "compatibility_date": "2026-04-30",
  "main": "_worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "stock-auth",
      "database_id": "YOUR_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}